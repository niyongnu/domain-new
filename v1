</header>

<main>
  <!-- Stats -->
  <div class="stats-row" id="stats-row">
    <div class="stat-card"><div class="stat-num blue" id="s-total">-</div><div class="stat-label">总域名数</div></div>
    <div class="stat-card"><div class="stat-num danger" id="s-expired">-</div><div class="stat-label">已过期</div></div>
    <div class="stat-card"><div class="stat-num warn" id="s-7">-</div><div class="stat-label">7天内到期</div></div>
    <div class="stat-card"><div class="stat-num warn" id="s-30">-</div><div class="stat-label">30天内到期</div></div>
    <div class="stat-card"><div class="stat-num green" id="s-ar">-</div><div class="stat-label">自动续约</div></div>
    <div class="stat-card"><div class="stat-num" id="s-acc">-</div><div class="stat-label">注册账号</div></div>
  </div>

  <!-- Domains Page -->
  <div id="page-domains" class="page active">
    <div class="section-header">
      <div class="section-title">域名列表 <span id="domain-count"></span></div>
      <button class="btn btn-primary" onclick="openAddDomain()">+ 添加域名</button>
    </div>
    <div class="toolbar">
      <div class="search-wrap">
        <span class="search-icon">🔍</span>
        <input class="search-input" id="domain-search" placeholder="搜索域名..." oninput="filterDomains()">
      </div>
      <select class="filter-select" id="domain-filter" onchange="filterDomains()">
        <option value="all">全部状态</option>
        <option value="expired">已过期</option>
        <option value="7">7天内到期</option>
        <option value="30">30天内到期</option>
        <option value="ok">正常</option>
      </select>
      <select class="filter-select" id="account-filter" onchange="filterDomains()">
        <option value="all">全部账号</option>
      </select>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>域名</th>
            <th>注册商</th>
            <th>到期状态</th>
            <th>到期日期</th>
            <th>账号</th>
            <th>自动续约</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody id="domains-tbody"></tbody>
      </table>
      <div class="empty" id="domains-empty" style="display:none">
        <div class="empty-icon">🌐</div>
        <h3>暂无域名记录</h3>
        <p>点击右上角按钮添加你的第一个域名</p>
      </div>
    </div>
  </div>

  <!-- Accounts Page -->
  <div id="page-accounts" class="page">
    <div class="section-header">
      <div class="section-title">注册账号</div>
      <button class="btn btn-primary" onclick="openAddAccount()">+ 添加账号</button>
    </div>
    <div class="accounts-grid" id="accounts-grid"></div>
    <div class="empty" id="accounts-empty" style="display:none">
      <div class="empty-icon">👤</div>
      <h3>暂无账号</h3>
      <p>添加你的域名注册商账号</p>
    </div>
  </div>

  <!-- Settings Page -->
  <div id="page-settings" class="page">
    <div class="section-title" style="margin-bottom:24px">Telegram 通知设置</div>
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:24px;max-width:560px">
      <div class="tg-status">
        <div class="tg-dot" id="tg-dot"></div>
        <span id="tg-status-text">加载中...</span>
      </div>
      <div class="form-group">
        <label class="form-label">Bot Token</label>
        <input class="form-input" id="tg-token" placeholder="从 @BotFather 获取 Token，格式: 123456:ABC-DEF...">
        <div class="form-help">在 Telegram 中向 @BotFather 发送 /newbot 创建机器人</div>
      </div>
      <div class="form-group">
        <label class="form-label">Chat ID</label>
        <input class="form-input" id="tg-chat" placeholder="向机器人发送 /start 获取你的 Chat ID">
        <div class="form-help">启动机器人后发送 /start，机器人会回复你的 Chat ID</div>
      </div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-primary" onclick="saveTgConfig()">保存设置</button>
        <button class="btn btn-secondary" onclick="testTelegram()">发送测试消息</button>
      </div>
      <div style="margin-top:24px;padding-top:24px;border-top:1px solid var(--border)">
        <div class="form-label" style="margin-bottom:12px">机器人命令说明</div>
        <div style="display:flex;flex-direction:column;gap:8px">
          <div style="display:flex;gap:8px;align-items:baseline"><code style="color:var(--accent);font-family:var(--mono);font-size:12px">/start</code><span style="color:var(--text2);font-size:13px">获取 Chat ID</span></div>
          <div style="display:flex;gap:8px;align-items:baseline"><code style="color:var(--accent);font-family:var(--mono);font-size:12px">/domains</code><span style="color:var(--text2);font-size:13px">查看所有域名</span></div>
          <div style="display:flex;gap:8px;align-items:baseline"><code style="color:var(--accent);font-family:var(--mono);font-size:12px">/expiring</code><span style="color:var(--text2);font-size:13px">查看30天内到期</span></div>
          <div style="display:flex;gap:8px;align-items:baseline"><code style="color:var(--accent);font-family:var(--mono);font-size:12px">/check</code><span style="color:var(--text2);font-size:13px">手动触发续约检查</span></div>
        </div>
      </div>
    </div>
  </div>
</main>
</div>

<!-- Domain Modal -->
<div class="modal-overlay" id="domain-modal">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title" id="domain-modal-title">添加域名</div>
      <button class="modal-close" onclick="closeModal('domain-modal')">×</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="edit-domain-id">
      <div class="form-group">
        <label class="form-label">域名 *</label>
        <input class="form-input" id="d-name" placeholder="example.com">
