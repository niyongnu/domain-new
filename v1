        <select class="form-select" id="d-account">
          <option value="">不关联账号</option>
        </select>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">注册日期</label>
          <input class="form-input" type="date" id="d-registered">
        </div>
        <div class="form-group">
          <label class="form-label">到期日期 *</label>
          <input class="form-input" type="date" id="d-expiry">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">提醒天数</label>
        <div class="reminder-tags" id="reminder-tags">
          <div class="reminder-tag selected" data-days="1">1天</div>
          <div class="reminder-tag selected" data-days="7">7天</div>
          <div class="reminder-tag selected" data-days="14">14天</div>
          <div class="reminder-tag selected" data-days="30">30天</div>
          <div class="reminder-tag" data-days="60">60天</div>
          <div class="reminder-tag" data-days="90">90天</div>
