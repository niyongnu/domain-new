      <div class="form-row">
        <div class="form-group">
          <label class="form-label">注册商</label>
          <input class="form-input" id="d-registrar" placeholder="Namecheap, GoDaddy...">
        </div>
        <div class="form-group">
          <label class="form-label">注册商控制台 URL</label>
