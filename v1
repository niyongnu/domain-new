</div>

<!-- Account Modal -->
<div class="modal-overlay" id="account-modal">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title" id="account-modal-title">添加账号</div>
      <button class="modal-close" onclick="closeModal('account-modal')">×</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="edit-account-id">
      <div class="form-group">
        <label class="form-label">账号名称 *</label>
        <input class="form-input" id="a-name" placeholder="如: 个人 Namecheap 账号">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">注册商</label>
          <input class="form-input" id="a-registrar" placeholder="Namecheap">
        </div>
        <div class="form-group">
          <label class="form-label">登录邮箱</label>
          <input class="form-input" id="a-email" placeholder="user@example.com">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">控制台 URL</label>
        <input class="form-input" id="a-url" placeholder="https://ap.www.namecheap.com">
      </div>
      <div class="form-group">
        <label class="form-label">备注</label>
        <textarea class="form-textarea" id="a-notes" placeholder="账号相关备注..."></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('account-modal')">取消</button>
      <button class="btn btn-primary" onclick="saveAccount()">保存</button>
    </div>
  </div>
</div>

<div id="toast"></div>

<script>
let allDomains = [], allAccounts = [];

// ── Auth ──────────────────────────────────────────────────────────────────
async function doLogin() {
  const pass = document.getElementById('login-pass').value;
  try {
    const r = await fetch('/api/login', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({password:pass}) });
    if (r.ok) { document.getElementById('login-screen').style.display='none'; document.getElementById('app').style.display='flex'; init(); }
    else { document.getElementById('login-err').textContent='密码错误'; }
  } catch { document.getElementById('login-err').textContent='连接失败'; }
}

document.getElementById('login-pass').addEventListener('keydown', e => { if(e.key==='Enter') doLogin(); });

async function doLogout() {
  await fetch('/api/logout', {method:'POST'});
  location.reload();
}

// ── Init ──────────────────────────────────────────────────────────────────
async function init() {
  await Promise.all([loadStats(), loadDomains(), loadAccounts(), loadTgConfig()]);
}

async function loadStats() {
  const r = await apiFetch('/api/stats');
  if (!r) return;
  document.getElementById('s-total').textContent = r.total;
  document.getElementById('s-expired').textContent = r.expired;
  document.getElementById('s-7').textContent = r.expiring7;
  document.getElementById('s-30').textContent = r.expiring30;
  document.getElementById('s-ar').textContent = r.autoRenew;
  document.getElementById('s-acc').textContent = r.accounts;
}

async function loadDomains() {
  allDomains = await apiFetch('/api/domains') || [];
  renderDomains(allDomains);
  updateAccountFilter();
}

async function loadAccounts() {
  allAccounts = await apiFetch('/api/accounts') || [];
  renderAccounts();
  updateAccountSelects();
}

async function loadTgConfig() {
  const c = await apiFetch('/api/telegram');
  if (!c) return;
  document.getElementById('tg-chat').value = c.chatId || '';
  if (c.botToken) document.getElementById('tg-token').placeholder = c.botToken;
  const active = !!c.chatId && c.botToken === '***已配置***';
  document.getElementById('tg-dot').className = 'tg-dot ' + (active ? 'on':'off');
  document.getElementById('tg-status-text').textContent = active ? 'Telegram 通知已启用' : '未配置 Telegram';
}

// ── Page Nav ──────────────────────────────────────────────────────────────
function showPage(name, btn) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  document.querySelectorAll('nav button').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

// ── Domains ───────────────────────────────────────────────────────────────
function renderDomains(domains) {
  const tbody = document.getElementById('domains-tbody');
  document.getElementById('domain-count').textContent = domains.length ? '(' + domains.length + ')' : '';
  
  if (!domains.length) {
    tbody.innerHTML = '';
    document.getElementById('domains-empty').style.display = 'block';
    return;
  }
  document.getElementById('domains-empty').style.display = 'none';
  
  tbody.innerHTML = domains.map(d => {
    const days = d.daysLeft;
    const badgeClass = days < 0 ? 'badge-danger' : days <= 7 ? 'badge-warn' : days <= 30 ? 'badge-warn' : 'badge-green';
    const badgeText = days < 0 ? '已过期 ' + Math.abs(days) + 'd' : days + ' 天';
    const barColor = days < 0 ? 'var(--danger)' : days <= 7 ? 'var(--danger)' : days <= 30 ? 'var(--warn)' : 'var(--accent)';
    const barW = Math.min(100, Math.max(0, (days / 365) * 100));
    const parts = d.name.split('.');
    const domainDisplay = parts.length > 1 ? parts.slice(0,-1).join('.') + '<span class="domain-tld">.' + parts[parts.length-1] + '</span>' : d.name;
    
    return \`<tr>
      <td><div class="domain-name">\${domainDisplay}</div></td>
      <td>\${d.registrarUrl ? \`<a class="registrar-link" href="\${d.registrarUrl}" target="_blank">\${d.registrar || '访问控制台'} ↗</a>\` : \`<span style="color:var(--text2)">\${d.registrar || '—'}</span>\`}</td>
      <td>
        <div class="days-wrap">
          <span class="badge \${badgeClass}">\${badgeText}</span>
          <div class="days-bar-bg"><div class="days-bar" style="width:\${barW}%;background:\${barColor}"></div></div>
        </div>
      </td>
      <td style="color:var(--text2);font-size:12px;font-family:var(--mono)">\${d.expiryDate}</td>
      <td><span class="badge badge-gray" style="font-family:var(--sans)">\${d.accountName}</span></td>
      <td>\${d.autoRenew ? '<span class="badge badge-green">✓ 自动</span>' : '<span class="badge badge-gray">手动</span>'}</td>
      <td>
        <div style="display:flex;gap:4px">
          <button class="btn btn-secondary btn-sm btn-icon" onclick='editDomain(\${JSON.stringify(d).replace(/'/g,"\\\\'")})'  title="编辑">✏️</button>
          <button class="btn btn-danger btn-sm btn-icon" onclick="deleteDomain('\${d.id}')" title="删除">🗑️</button>
        </div>
      </td>
    </tr>\`;
  }).join('');
}

function filterDomains() {
  const q = document.getElementById('domain-search').value.toLowerCase();
  const f = document.getElementById('domain-filter').value;
  const af = document.getElementById('account-filter').value;
  
  let filtered = allDomains.filter(d => {
    if (q && !d.name.includes(q)) return false;
    if (af !== 'all' && d.accountId !== af) return false;
    if (f === 'expired') return d.daysLeft < 0;
    if (f === '7') return d.daysLeft >= 0 && d.daysLeft <= 7;
    if (f === '30') return d.daysLeft >= 0 && d.daysLeft <= 30;
    if (f === 'ok') return d.daysLeft > 30;
    return true;
  });
  renderDomains(filtered);
}

function updateAccountFilter() {
  const sel = document.getElementById('account-filter');
  const cur = sel.value;
  sel.innerHTML = '<option value="all">全部账号</option>' +
    allAccounts.map(a => \`<option value="\${a.id}">\${a.name}</option>\`).join('');
  sel.value = cur;
}

function openAddDomain() {
  document.getElementById('domain-modal-title').textContent = '添加域名';
  document.getElementById('edit-domain-id').value = '';
  document.getElementById('d-name').value = '';
  document.getElementById('d-registrar').value = '';
  document.getElementById('d-registrar-url').value = '';
  document.getElementById('d-account').value = '';
  document.getElementById('d-registered').value = '';
  document.getElementById('d-expiry').value = '';
  document.getElementById('d-autorenew').checked = false;
  document.getElementById('d-notes').value = '';
  document.querySelectorAll('.reminder-tag').forEach(t => {
    t.classList.toggle('selected', ['1','7','30'].includes(t.dataset.days));
  });
  openModal('domain-modal');
}

