// ─── Route Dispatcher ──────────────────────────────────────────────────────

export default {
  async fetch(request, env, ctx) {
    const url = new URL(request.url);
    const path = url.pathname;

    // 鉴权中间件
    if (!path.startsWith('/api/telegram/webhook')) {
      const authResult = await authenticate(request, env);
      if (!authResult.ok) return authResult.response;
    }

    // 路由分发
    if (path === '/' || path === '/index.html') return serveHTML();
    if (path.startsWith('/api/')) return handleAPI(request, env, url, path);
    return new Response('Not Found', { status: 404 });
  },

  async scheduled(event, env, ctx) {
    ctx.waitUntil(runDailyCheck(env));
  },
};

// ─── Auth ───────────────────────────────────────────────────────────────────

async function authenticate(request, env) {
  const adminPassword = env.ADMIN_PASSWORD || 'admin123';
  const cookie = request.headers.get('Cookie') || '';
  const token = extractCookie(cookie, 'auth_token');

  if (token) {
    const valid = await verifyToken(token, adminPassword);
    if (valid) return { ok: true };
  }

  const url = new URL(request.url);
  if (url.pathname === '/api/login' && request.method === 'POST') {
    return { ok: true };
  }

  if (url.pathname !== '/' && url.pathname.startsWith('/api/')) {
    return { ok: false, response: json({ error: 'Unauthorized' }, 401) };
  }

  return { ok: true };
}

async function verifyToken(token, password) {
  try {
    const [payload, sig] = token.split('.');
    const expected = await hmacSign(payload, password);
    return sig === expected && Date.now() < JSON.parse(atob(payload)).exp;
  } catch { return false; }
}

async function createToken(password) {
  const payload = btoa(JSON.stringify({ exp: Date.now() + 86400000 * 7 }));
  const sig = await hmacSign(payload, password);
  return `${payload}.${sig}`;
}

async function hmacSign(data, key) {
  const enc = new TextEncoder();
  const k = await crypto.subtle.importKey('raw', enc.encode(key), { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']);
  const sig = await crypto.subtle.sign('HMAC', k, enc.encode(data));
  return btoa(String.fromCharCode(...new Uint8Array(sig)));
}

function extractCookie(cookieStr, name) {
  const match = cookieStr.match(new RegExp(`(?:^|;\\s*)${name}=([^;]*)`));
  return match ? match[1] : null;
}

// ─── API Router ─────────────────────────────────────────────────────────────

async function handleAPI(request, env, url, path) {
  const method = request.method;

  try {
    // 登录
    if (path === '/api/login' && method === 'POST') {
      const { password } = await request.json();
      const adminPassword = env.ADMIN_PASSWORD || 'admin123';
      if (password !== adminPassword) return json({ error: '密码错误' }, 401);
      const token = await createToken(adminPassword);
      return new Response(JSON.stringify({ ok: true }), {
        headers: {
          'Content-Type': 'application/json',
          'Set-Cookie': `auth_token=${token}; Path=/; HttpOnly; SameSite=Strict; Max-Age=604800`,
        },
      });
    }

    if (path === '/api/logout' && method === 'POST') {
      return new Response(JSON.stringify({ ok: true }), {
        headers: {
          'Content-Type': 'application/json',
          'Set-Cookie': 'auth_token=; Path=/; HttpOnly; Max-Age=0',
        },
      });
    }

    // 域名 CRUD
    if (path === '/api/domains' && method === 'GET') return getDomains(env);
    if (path === '/api/domains' && method === 'POST') return addDomain(request, env);
    if (path.match(/^\/api\/domains\/[^/]+$/) && method === 'PUT') return updateDomain(request, env, path);
    if (path.match(/^\/api\/domains\/[^/]+$/) && method === 'DELETE') return deleteDomain(env, path);

    // 账号 CRUD
    if (path === '/api/accounts' && method === 'GET') return getAccounts(env);
    if (path === '/api/accounts' && method === 'POST') return addAccount(request, env);
    if (path.match(/^\/api\/accounts\/[^/]+$/) && method === 'PUT') return updateAccount(request, env, path);
    if (path.match(/^\/api\/accounts\/[^/]+$/) && method === 'DELETE') return deleteAccount(env, path);

    // Telegram 设置
    if (path === '/api/telegram' && method === 'GET') return getTelegramConfig(env);
    if (path === '/api/telegram' && method === 'POST') return saveTelegramConfig(request, env);

    // Telegram webhook
    if (path === '/api/telegram/webhook' && method === 'POST') return handleTelegramWebhook(request, env);

    // 统计
    if (path === '/api/stats' && method === 'GET') return getStats(env);

    // 手动触发检查
    if (path === '/api/check' && method === 'POST') {
      await runDailyCheck(env);
      return json({ ok: true, message: '续约检查已执行' });
    }

    return json({ error: 'Not Found' }, 404);
  } catch (e) {
    return json({ error: e.message }, 500);
  }
}

// ─── Domain APIs ────────────────────────────────────────────────────────────

async function getDomains(env) {
  const raw = await env.KV.get('domains');
  const domains = raw ? JSON.parse(raw) : [];
  const accounts = await getAccountsData(env);
  const accountMap = Object.fromEntries(accounts.map(a => [a.id, a]));

  const enriched = domains.map(d => ({
    ...d,
    accountName: accountMap[d.accountId]?.name || '未知账号',
    daysLeft: daysUntil(d.expiryDate),
  })).sort((a, b) => a.daysLeft - b.daysLeft);

  return json(enriched);
}

async function addDomain(request, env) {
  const body = await request.json();
  const domains = await getDomainsData(env);
  const domain = {
    id: crypto.randomUUID(),
    name: body.name?.trim().toLowerCase(),
    accountId: body.accountId,
    registrar: body.registrar?.trim(),
    registrarUrl: body.registrarUrl?.trim(),
    registeredAt: body.registeredAt,
    expiryDate: body.expiryDate,
    autoRenew: body.autoRenew || false,
    reminderDays: body.reminderDays || [30, 7, 1],
    notes: body.notes || '',
    createdAt: new Date().toISOString(),
  };
  if (!domain.name || !domain.expiryDate) return json({ error: '域名和到期日期为必填项' }, 400);
  domains.push(domain);
  await env.KV.put('domains', JSON.stringify(domains));
  return json(domain);
}

async function updateDomain(request, env, path) {
  const id = path.split('/').pop();
  const body = await request.json();
  const domains = await getDomainsData(env);
  const idx = domains.findIndex(d => d.id === id);
  if (idx === -1) return json({ error: '域名不存在' }, 404);
  domains[idx] = { ...domains[idx], ...body, id, updatedAt: new Date().toISOString() };
  await env.KV.put('domains', JSON.stringify(domains));
  return json(domains[idx]);
}

async function deleteDomain(env, path) {
  const id = path.split('/').pop();
  const domains = await getDomainsData(env);
  const filtered = domains.filter(d => d.id !== id);
  await env.KV.put('domains', JSON.stringify(filtered));
  return json({ ok: true });
}

// ─── Account APIs ────────────────────────────────────────────────────────────

async function getAccounts(env) {
  const accounts = await getAccountsData(env);
  return json(accounts);
}

async function addAccount(request, env) {
  const body = await request.json();
  const accounts = await getAccountsData(env);
  const account = {
    id: crypto.randomUUID(),
    name: body.name?.trim(),
    registrar: body.registrar?.trim(),
    loginUrl: body.loginUrl?.trim(),
    email: body.email?.trim(),
    notes: body.notes || '',
    createdAt: new Date().toISOString(),
  };
  if (!account.name) return json({ error: '账号名称为必填项' }, 400);
  accounts.push(account);
  await env.KV.put('accounts', JSON.stringify(accounts));
  return json(account);
}

async function updateAccount(request, env, path) {
  const id = path.split('/').pop();
  const body = await request.json();
  const accounts = await getAccountsData(env);
  const idx = accounts.findIndex(a => a.id === id);
  if (idx === -1) return json({ error: '账号不存在' }, 404);
  accounts[idx] = { ...accounts[idx], ...body, id };
  await env.KV.put('accounts', JSON.stringify(accounts));
  return json(accounts[idx]);
}

async function deleteAccount(env, path) {
  const id = path.split('/').pop();
  const accounts = await getAccountsData(env);
  await env.KV.put('accounts', JSON.stringify(accounts.filter(a => a.id !== id)));
  return json({ ok: true });
}

// ─── Telegram ───────────────────────────────────────────────────────────────

async function getTelegramConfig(env) {
  const raw = await env.KV.get('telegram_config');
  const config = raw ? JSON.parse(raw) : {};
  return json({ chatId: config.chatId || '', webhookSet: !!config.botToken, botToken: config.botToken ? '***已配置***' : '' });
}

async function saveTelegramConfig(request, env) {
  const body = await request.json();
  const existing = JSON.parse((await env.KV.get('telegram_config')) || '{}');
  const config = {
    ...existing,
    chatId: body.chatId,
    ...(body.botToken && body.botToken !== '***已配置***' ? { botToken: body.botToken } : {}),
  };
  await env.KV.put('telegram_config', JSON.stringify(config));
  return json({ ok: true });
}

async function handleTelegramWebhook(request, env) {
  const update = await request.json();
  const msg = update.message;
  if (!msg) return json({ ok: true });

  const chatId = msg.chat.id;
  const text = msg.text || '';
  const config = JSON.parse((await env.KV.get('telegram_config')) || '{}');

  if (text === '/start') {
    await sendTelegram(config.botToken, chatId, `🌐 *域名管理机器人*\n\n你的 Chat ID 是: \`${chatId}\`\n\n请将此 ID 填写到管理后台的 Telegram 设置中。\n\n可用命令:\n/domains - 查看所有域名\n/expiring - 查看即将到期域名\n/check - 立即检查续约`);
  } else if (text === '/domains') {
    const domains = await getDomainsData(env);
    if (!domains.length) return sendTelegram(config.botToken, chatId, '📭 暂无域名记录');
    const list = domains.sort((a, b) => daysUntil(a.expiryDate) - daysUntil(b.expiryDate))
      .map(d => `${statusEmoji(daysUntil(d.expiryDate))} \`${d.name}\` — ${daysUntil(d.expiryDate)} 天后到期`)
      .join('\n');
    await sendTelegram(config.botToken, chatId, `🌐 *所有域名*\n\n${list}`);
  } else if (text === '/expiring') {
    await sendExpiryReport(config, chatId, env);
  } else if (text === '/check') {
    await runDailyCheck(env);
    await sendTelegram(config.botToken, chatId, '✅ 续约检查已完成');
  }

  return json({ ok: true });
}

// ─── Stats ───────────────────────────────────────────────────────────────────

async function getStats(env) {
  const domains = await getDomainsData(env);
  const accounts = await getAccountsData(env);

  const stats = {
    total: domains.length,
    accounts: accounts.length,
    expiring7: domains.filter(d => daysUntil(d.expiryDate) <= 7).length,
    expiring30: domains.filter(d => daysUntil(d.expiryDate) <= 30).length,
    expired: domains.filter(d => daysUntil(d.expiryDate) < 0).length,
    autoRenew: domains.filter(d => d.autoRenew).length,
  };
  return json(stats);
}

// ─── Daily Check & Notifications ────────────────────────────────────────────

async function runDailyCheck(env) {
  const config = JSON.parse((await env.KV.get('telegram_config')) || '{}');
  if (!config.botToken || !config.chatId) return;

  const domains = await getDomainsData(env);
  const today = new Date().toDateString();
  const lastRun = await env.KV.get('last_check_date');

  // 防止同天重复发送
  if (lastRun === today) return;
  await env.KV.put('last_check_date', today);

  const toNotify = domains.filter(d => {
    const days = daysUntil(d.expiryDate);
    const reminders = d.reminderDays || [30, 7, 1];
    return reminders.includes(days) || days < 0;
  });

  if (toNotify.length === 0) return;

  const lines = toNotify.map(d => {
    const days = daysUntil(d.expiryDate);
    const emoji = days < 0 ? '🔴' : days <= 1 ? '🆘' : days <= 7 ? '🟠' : '🟡';
    const status = days < 0 ? `已过期 ${Math.abs(days)} 天` : `${days} 天后到期`;
    return `${emoji} \`${d.name}\`\n   注册商: ${d.registrar || '未知'}\n   状态: ${status}`;
  }).join('\n\n');

  const msg = `⚠️ *域名续约提醒*\n\n${lines}\n\n请及时前往注册商控制台续约。`;
  await sendTelegram(config.botToken, config.chatId, msg);
}

async function sendExpiryReport(config, chatId, env) {
  const domains = await getDomainsData(env);
  const expiring = domains.filter(d => daysUntil(d.expiryDate) <= 30)
    .sort((a, b) => daysUntil(a.expiryDate) - daysUntil(b.expiryDate));

  if (!expiring.length) {
    return sendTelegram(config.botToken, chatId, '✅ 未来 30 天内没有即将到期的域名');
  }

  const list = expiring.map(d => `${statusEmoji(daysUntil(d.expiryDate))} \`${d.name}\` — ${daysUntil(d.expiryDate)} 天`).join('\n');
  await sendTelegram(config.botToken, chatId, `⏰ *30天内到期域名*\n\n${list}`);
}

async function sendTelegram(token, chatId, text) {
  if (!token) return;
  await fetch(`https://api.telegram.org/bot${token}/sendMessage`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ chat_id: chatId, text, parse_mode: 'Markdown' }),
  });
}

// ─── Helpers ─────────────────────────────────────────────────────────────────

function daysUntil(dateStr) {
  const exp = new Date(dateStr);
  const now = new Date();
  exp.setHours(0, 0, 0, 0);
  now.setHours(0, 0, 0, 0);
  return Math.round((exp - now) / 86400000);
}

function statusEmoji(days) {
  if (days < 0) return '🔴';
  if (days <= 7) return '🟠';
  if (days <= 30) return '🟡';
  return '🟢';
}

async function getDomainsData(env) {
  const raw = await env.KV.get('domains');
  return raw ? JSON.parse(raw) : [];
}

async function getAccountsData(env) {
  const raw = await env.KV.get('accounts');
  return raw ? JSON.parse(raw) : [];
}

function json(data, status = 200) {
  return new Response(JSON.stringify(data), {
    status,
    headers: { 'Content-Type': 'application/json' },
  });
}

