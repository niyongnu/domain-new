/**
 * Domain Manager - Cloudflare Worker v2
 * 多账号域名管理 + Cloudflare 账号同步 + Telegram 续约提醒
 */

export default {
  async fetch(request, env, ctx) {
    const url = new URL(request.url);
    const path = url.pathname;
    if (!path.startsWith('/api/telegram/webhook')) {
      const auth = await authenticate(request, env);
      if (!auth.ok) return auth.response;
    }
    if (path === '/' || path === '/index.html') return serveHTML();
    if (path.startsWith('/api/')) return handleAPI(request, env, url, path);
    return new Response('Not Found', { status: 404 });
  },
  async scheduled(event, env, ctx) {
    ctx.waitUntil(runDailyCheck(env));
  },
};

// ─── Auth ────────────────────────────────────────────────────────────────────

async function authenticate(request, env) {
  const adminPassword = env.ADMIN_PASSWORD || 'admin123';
  const cookie = request.headers.get('Cookie') || '';
  const token = extractCookie(cookie, 'auth_token');
  if (token && await verifyToken(token, adminPassword)) return { ok: true };
  const url = new URL(request.url);
  if (url.pathname === '/api/login' && request.method === 'POST') return { ok: true };
  if (url.pathname !== '/' && url.pathname.startsWith('/api/'))
    return { ok: false, response: json({ error: 'Unauthorized' }, 401) };
  return { ok: true };
}

async function verifyToken(token, password) {
  try {
    const [payload, sig] = token.split('.');
    const expected = await hmacSign(payload, password);
    return sig === expected && Date.now() < JSON.parse(atob(payload)).exp;
  } catch { return false; }
}

async function createToken(password) {
  const payload = btoa(JSON.stringify({ exp: Date.now() + 86400000 * 7 }));
  return `${payload}.${await hmacSign(payload, password)}`;
}

async function hmacSign(data, key) {
  const enc = new TextEncoder();
  const k = await crypto.subtle.importKey('raw', enc.encode(key), { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']);
  const sig = await crypto.subtle.sign('HMAC', k, enc.encode(data));
  return btoa(String.fromCharCode(...new Uint8Array(sig)));
}

function extractCookie(cookieStr, name) {
  const match = cookieStr.match(new RegExp(`(?:^|;\\s*)${name}=([^;]*)`));
  return match ? match[1] : null;
}

// ─── API Router ───────────────────────────────────────────────────────────────

async function handleAPI(request, env, url, path) {
  const method = request.method;
  try {
    if (path === '/api/login' && method === 'POST') {
      const { password } = await request.json();
      if (password !== (env.ADMIN_PASSWORD || 'admin123')) return json({ error: '密码错误' }, 401);
      const token = await createToken(env.ADMIN_PASSWORD || 'admin123');
      return new Response(JSON.stringify({ ok: true }), {
        headers: { 'Content-Type': 'application/json', 'Set-Cookie': `auth_token=${token}; Path=/; HttpOnly; SameSite=Strict; Max-Age=604800` },
      });
    }
    if (path === '/api/logout' && method === 'POST')
      return new Response(JSON.stringify({ ok: true }), {
        headers: { 'Content-Type': 'application/json', 'Set-Cookie': 'auth_token=; Path=/; HttpOnly; Max-Age=0' },
      });

    // 域名
    if (path === '/api/domains' && method === 'GET') return getDomains(env);
    if (path === '/api/domains' && method === 'POST') return addDomain(request, env);
    if (path.match(/^\/api\/domains\/[^/]+$/) && method === 'PUT') return updateDomain(request, env, path);
    if (path.match(/^\/api\/domains\/[^/]+$/) && method === 'DELETE') return deleteDomain(env, path);

    // 账号
    if (path === '/api/accounts' && method === 'GET') return getAccounts(env);
    if (path === '/api/accounts' && method === 'POST') return addAccount(request, env);
    if (path.match(/^\/api\/accounts\/[^/]+$/) && method === 'PUT') return updateAccount(request, env, path);
    if (path.match(/^\/api\/accounts\/[^/]+$/) && method === 'DELETE') return deleteAccount(env, path);

    // Cloudflare 同步
    if (path === '/api/cf-accounts' && method === 'GET') return getCFAccounts(env);
    if (path === '/api/cf-accounts' && method === 'POST') return addCFAccount(request, env);
    if (path.match(/^\/api\/cf-accounts\/[^/]+$/) && method === 'DELETE') return deleteCFAccount(env, path);
    if (path === '/api/cf-sync' && method === 'POST') return syncCFDomains(request, env);
    if (path === '/api/cf-preview' && method === 'POST') return previewCFDomains(request, env);

    // Telegram
    if (path === '/api/telegram' && method === 'GET') return getTelegramConfig(env);
    if (path === '/api/telegram' && method === 'POST') return saveTelegramConfig(request, env);
    if (path === '/api/telegram/webhook' && method === 'POST') return handleTelegramWebhook(request, env);

    // 统计 & 检查
    if (path === '/api/stats' && method === 'GET') return getStats(env);
    if (path === '/api/check' && method === 'POST') { await runDailyCheck(env); return json({ ok: true, message: '续约检查已执行' }); }

    return json({ error: 'Not Found' }, 404);
  } catch (e) {
    return json({ error: e.message }, 500);
  }
}

// ─── Domain CRUD ──────────────────────────────────────────────────────────────

async function getDomains(env) {
  const domains = await getDomainsData(env);
  const accounts = await getAccountsData(env);
  const cfAccounts = await getCFAccountsData(env);
  const accountMap = Object.fromEntries([...accounts, ...cfAccounts].map(a => [a.id, a]));
  return json(domains.map(d => ({ ...d, accountName: accountMap[d.accountId]?.name || '未知账号', daysLeft: daysUntil(d.expiryDate) }))
    .sort((a, b) => a.daysLeft - b.daysLeft));
}

async function addDomain(request, env) {
  const body = await request.json();
  const domains = await getDomainsData(env);
  const domain = { id: crypto.randomUUID(), name: body.name?.trim().toLowerCase(), accountId: body.accountId, registrar: body.registrar?.trim(), registrarUrl: body.registrarUrl?.trim(), registeredAt: body.registeredAt, expiryDate: body.expiryDate, autoRenew: body.autoRenew || false, reminderDays: body.reminderDays || [30, 7, 1], notes: body.notes || '', source: body.source || 'manual', createdAt: new Date().toISOString() };
  if (!domain.name || !domain.expiryDate) return json({ error: '域名和到期日期为必填项' }, 400);
  domains.push(domain);
  await env.KV.put('domains', JSON.stringify(domains));
  return json(domain);
}

async function updateDomain(request, env, path) {
  const id = path.split('/').pop();
  const body = await request.json();
  const domains = await getDomainsData(env);
  const idx = domains.findIndex(d => d.id === id);
  if (idx === -1) return json({ error: '域名不存在' }, 404);
  domains[idx] = { ...domains[idx], ...body, id, updatedAt: new Date().toISOString() };
  await env.KV.put('domains', JSON.stringify(domains));
  return json(domains[idx]);
}

async function deleteDomain(env, path) {
  const id = path.split('/').pop();
  const domains = await getDomainsData(env);
  await env.KV.put('domains', JSON.stringify(domains.filter(d => d.id !== id)));
  return json({ ok: true });
}

// ─── Account CRUD ─────────────────────────────────────────────────────────────

async function getAccounts(env) { return json(await getAccountsData(env)); }

async function addAccount(request, env) {
  const body = await request.json();
  const accounts = await getAccountsData(env);
  const account = { id: crypto.randomUUID(), name: body.name?.trim(), registrar: body.registrar?.trim(), loginUrl: body.loginUrl?.trim(), email: body.email?.trim(), notes: body.notes || '', createdAt: new Date().toISOString() };
  if (!account.name) return json({ error: '账号名称为必填项' }, 400);
  accounts.push(account);
  await env.KV.put('accounts', JSON.stringify(accounts));
  return json(account);
}

async function updateAccount(request, env, path) {
  const id = path.split('/').pop();
  const body = await request.json();
  const accounts = await getAccountsData(env);
  const idx = accounts.findIndex(a => a.id === id);
  if (idx === -1) return json({ error: '账号不存在' }, 404);
  accounts[idx] = { ...accounts[idx], ...body, id };
  await env.KV.put('accounts', JSON.stringify(accounts));
  return json(accounts[idx]);
}

async function deleteAccount(env, path) {
  const id = path.split('/').pop();
  await env.KV.put('accounts', JSON.stringify((await getAccountsData(env)).filter(a => a.id !== id)));
  return json({ ok: true });
}

// ─── Cloudflare Account Sync ──────────────────────────────────────────────────

async function getCFAccounts(env) {
  const accounts = await getCFAccountsData(env);
  return json(accounts.map(a => ({ ...a, apiToken: a.apiToken ? '***已配置***' : '' })));
}

async function addCFAccount(request, env) {
  const body = await request.json();
  if (!body.apiToken || !body.name) return json({ error: '名称和 API Token 为必填项' }, 400);

  // 验证 token 并获取账号信息
  const verify = await cfAPI('/accounts', body.apiToken);
  if (!verify.success) return json({ error: 'API Token 无效: ' + (verify.errors?.[0]?.message || '验证失败') }, 400);

  const accounts = await getCFAccountsData(env);
  const account = {
    id: crypto.randomUUID(),
    name: body.name.trim(),
    apiToken: body.apiToken.trim(),
    cfAccountId: verify.result?.[0]?.id || '',
    cfAccountName: verify.result?.[0]?.name || '',
    type: 'cloudflare',
    createdAt: new Date().toISOString(),
  };
  accounts.push(account);
  await env.KV.put('cf_accounts', JSON.stringify(accounts));
  return json({ ...account, apiToken: '***已配置***' });
}

async function deleteCFAccount(env, path) {
  const id = path.split('/').pop();
  await env.KV.put('cf_accounts', JSON.stringify((await getCFAccountsData(env)).filter(a => a.id !== id)));
  return json({ ok: true });
}

async function previewCFDomains(request, env) {
  const { cfAccountId } = await request.json();
  const cfAccounts = await getCFAccountsData(env);
  const cfAccount = cfAccounts.find(a => a.id === cfAccountId);
  if (!cfAccount) return json({ error: '找不到该 Cloudflare 账号' }, 404);

  const result = await fetchCFDomains(cfAccount);
  if (!result.success) return json({ error: result.error }, 400);

  // 对比已有域名
  const existingDomains = await getDomainsData(env);
  const existingNames = new Set(existingDomains.map(d => d.name));
  const preview = result.domains.map(d => ({ ...d, exists: existingNames.has(d.name) }));

  return json({ domains: preview, total: preview.length, newCount: preview.filter(d => !d.exists).length });
}

async function syncCFDomains(request, env) {
  const { cfAccountId, mode = 'new' } = await request.json(); // mode: 'new' | 'all'
  const cfAccounts = await getCFAccountsData(env);
  const cfAccount = cfAccounts.find(a => a.id === cfAccountId);
  if (!cfAccount) return json({ error: '找不到该 Cloudflare 账号' }, 404);

  const result = await fetchCFDomains(cfAccount);
  if (!result.success) return json({ error: result.error }, 400);

  const domains = await getDomainsData(env);
  const existingMap = new Map(domains.map(d => [d.name, d]));

  let added = 0, updated = 0, skipped = 0;

  for (const cfDomain of result.domains) {
    if (existingMap.has(cfDomain.name)) {
      if (mode === 'all') {
        // 更新到期日期
        const idx = domains.findIndex(d => d.name === cfDomain.name);
        domains[idx] = { ...domains[idx], expiryDate: cfDomain.expiryDate, autoRenew: cfDomain.autoRenew, updatedAt: new Date().toISOString(), source: 'cloudflare' };
        updated++;
      } else {
        skipped++;
      }
    } else {
      domains.push({
        id: crypto.randomUUID(),
        name: cfDomain.name,
        accountId: cfAccount.id,
        registrar: 'Cloudflare',
        registrarUrl: `https://dash.cloudflare.com/${cfAccount.cfAccountId}/domains`,
        registeredAt: cfDomain.registeredAt,
        expiryDate: cfDomain.expiryDate,
        autoRenew: cfDomain.autoRenew,
        reminderDays: [1, 7, 30],
        notes: '',
        source: 'cloudflare',
        createdAt: new Date().toISOString(),
      });
      added++;
    }
  }

  await env.KV.put('domains', JSON.stringify(domains));
  return json({ ok: true, added, updated, skipped, total: result.domains.length });
}

async function fetchCFDomains(cfAccount) {
  try {
    // 优先用 Registrar API（有完整到期时间）
    let domains = [];

    // 1. 获取 Registrar 域名（通过 Cloudflare 注册的域名，有到期日期）
    const registrarRes = await cfAPI(`/accounts/${cfAccount.cfAccountId}/registrar/domains?per_page=200`, cfAccount.apiToken);
    if (registrarRes.success && registrarRes.result?.length > 0) {
      for (const d of registrarRes.result) {
        domains.push({
          name: d.name,
          registeredAt: d.created_at ? d.created_at.split('T')[0] : '',
          expiryDate: d.expires_at ? d.expires_at.split('T')[0] : '',
          autoRenew: d.auto_renew || false,
          source: 'cf_registrar',
        });
      }
    }

    // 2. 获取 Zone 列表（所有托管域名，包括非 CF 注册的）
    const zonesRes = await cfAPI('/zones?per_page=200&status=active', cfAccount.apiToken);
    if (zonesRes.success) {
      const registrarNames = new Set(domains.map(d => d.name));
      for (const z of zonesRes.result || []) {
        if (!registrarNames.has(z.name)) {
          domains.push({
            name: z.name,
            registeredAt: z.created_on ? z.created_on.split('T')[0] : '',
            expiryDate: '', // Zone 不含到期日期，需手动填写
            autoRenew: false,
            source: 'cf_zone',
          });
        }
      }
    }

    if (domains.length === 0) return { success: false, error: '未找到任何域名，请检查 API Token 权限' };
    return { success: true, domains };
  } catch (e) {
    return { success: false, error: e.message };
  }
}

async function cfAPI(endpoint, token) {
  const res = await fetch(`https://api.cloudflare.com/client/v4${endpoint}`, {
    headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
  });
  return res.json();
}

// ─── Telegram ─────────────────────────────────────────────────────────────────

async function getTelegramConfig(env) {
  const raw = await env.KV.get('telegram_config');
  const config = raw ? JSON.parse(raw) : {};
  return json({ chatId: config.chatId || '', botToken: config.botToken ? '***已配置***' : '' });
}

async function saveTelegramConfig(request, env) {
  const body = await request.json();
  const existing = JSON.parse((await env.KV.get('telegram_config')) || '{}');
  const config = { ...existing, chatId: body.chatId, ...(body.botToken && body.botToken !== '***已配置***' ? { botToken: body.botToken } : {}) };
  await env.KV.put('telegram_config', JSON.stringify(config));
  return json({ ok: true });
}

async function handleTelegramWebhook(request, env) {
  const update = await request.json();
  const msg = update.message;
  if (!msg) return json({ ok: true });
  const chatId = msg.chat.id;
  const text = msg.text || '';
  const config = JSON.parse((await env.KV.get('telegram_config')) || '{}');
  if (text === '/start') {
    await sendTelegram(config.botToken, chatId, `🌐 *域名管理机器人*\n\n你的 Chat ID 是: \`${chatId}\`\n\n命令列表:\n/domains - 所有域名\n/expiring - 即将到期\n/check - 立即检查`);
  } else if (text === '/domains') {
    const domains = await getDomainsData(env);
    const list = domains.sort((a, b) => daysUntil(a.expiryDate) - daysUntil(b.expiryDate)).map(d => `${statusEmoji(daysUntil(d.expiryDate))} \`${d.name}\` — ${daysUntil(d.expiryDate)} 天`).join('\n');
    await sendTelegram(config.botToken, chatId, `🌐 *所有域名*\n\n${list || '暂无域名'}`);
  } else if (text === '/expiring') {
    const domains = await getDomainsData(env);
    const exp = domains.filter(d => daysUntil(d.expiryDate) <= 30).sort((a, b) => daysUntil(a.expiryDate) - daysUntil(b.expiryDate));
    const list = exp.map(d => `${statusEmoji(daysUntil(d.expiryDate))} \`${d.name}\` — ${daysUntil(d.expiryDate)} 天`).join('\n');
    await sendTelegram(config.botToken, chatId, exp.length ? `⏰ *30天内到期*\n\n${list}` : '✅ 30天内无到期域名');
  } else if (text === '/check') {
    await runDailyCheck(env);
    await sendTelegram(config.botToken, chatId, '✅ 续约检查完成');
  }
  return json({ ok: true });
}

// ─── Stats ────────────────────────────────────────────────────────────────────

async function getStats(env) {
  const domains = await getDomainsData(env);
  const accounts = await getAccountsData(env);
  const cfAccounts = await getCFAccountsData(env);
  return json({
    total: domains.length, accounts: accounts.length + cfAccounts.length,
    expiring7: domains.filter(d => daysUntil(d.expiryDate) >= 0 && daysUntil(d.expiryDate) <= 7).length,
    expiring30: domains.filter(d => daysUntil(d.expiryDate) >= 0 && daysUntil(d.expiryDate) <= 30).length,
    expired: domains.filter(d => daysUntil(d.expiryDate) < 0).length,
    autoRenew: domains.filter(d => d.autoRenew).length,
    cfDomains: domains.filter(d => d.source === 'cloudflare' || d.source === 'cf_registrar' || d.source === 'cf_zone').length,
  });
}

// ─── Daily Check ──────────────────────────────────────────────────────────────

async function runDailyCheck(env) {
  const config = JSON.parse((await env.KV.get('telegram_config')) || '{}');
  if (!config.botToken || !config.chatId) return;
  const today = new Date().toDateString();
  if (await env.KV.get('last_check_date') === today) return;
  await env.KV.put('last_check_date', today);
  const domains = await getDomainsData(env);
  const toNotify = domains.filter(d => { const days = daysUntil(d.expiryDate); return (d.reminderDays || [30,7,1]).includes(days) || days < 0; });
  if (!toNotify.length) return;
  const lines = toNotify.map(d => { const days = daysUntil(d.expiryDate); return `${days < 0 ? '🔴' : days <= 1 ? '🆘' : days <= 7 ? '🟠' : '🟡'} \`${d.name}\` — ${days < 0 ? '已过期 ' + Math.abs(days) + ' 天' : days + ' 天后到期'}\n   注册商: ${d.registrar || '未知'}`; }).join('\n\n');
  await sendTelegram(config.botToken, config.chatId, `⚠️ *域名续约提醒*\n\n${lines}`);
}

async function sendTelegram(token, chatId, text) {
  if (!token) return;
  await fetch(`https://api.telegram.org/bot${token}/sendMessage`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ chat_id: chatId, text, parse_mode: 'Markdown' }),
  });
}

// ─── Helpers ──────────────────────────────────────────────────────────────────

function daysUntil(dateStr) {
  if (!dateStr) return 9999;
  const exp = new Date(dateStr); const now = new Date();
  exp.setHours(0,0,0,0); now.setHours(0,0,0,0);
  return Math.round((exp - now) / 86400000);
}
function statusEmoji(days) { return days < 0 ? '🔴' : days <= 7 ? '🟠' : days <= 30 ? '🟡' : '🟢'; }
async function getDomainsData(env) { return JSON.parse((await env.KV.get('domains')) || '[]'); }
async function getAccountsData(env) { return JSON.parse((await env.KV.get('accounts')) || '[]'); }
async function getCFAccountsData(env) { return JSON.parse((await env.KV.get('cf_accounts')) || '[]'); }
function json(data, status = 200) { return new Response(JSON.stringify(data), { status, headers: { 'Content-Type': 'application/json' } }); }

